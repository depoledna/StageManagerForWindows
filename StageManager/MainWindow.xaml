<Window
    x:Class="StageManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:StageManager"
    xmlns:controls="clr-namespace:StageManager.Controls"
    xmlns:conv="clr-namespace:StageManager.Converters"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    mc:Ignorable="d"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None"
    Title="MainWindow"
    Height="450"
    Width="180"
    ShowActivated="False"
    Background="Transparent"
    Name="thisWindow">
    <Window.Resources>
        <Style
            x:Key="SceneOpacity"
            TargetType="{x:Type Grid}">
            <Setter
                Property="Opacity"
                Value="0.8" />
            <Style.Triggers>
                <Trigger
                    Property="IsMouseOver"
                    Value="true">
                    <Setter
                        Property="Opacity"
                        Value="1" />
                </Trigger>
                <Trigger
                    Property="IsMouseOver"
                    Value="false">
                    <Setter
                        Property="Opacity"
                        Value="0.8" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <conv:IndexToOffsetMarginConverter x:Key="IndexToOffsetMarginConverter" />
        <conv:IndexToZIndexConverter x:Key="IndexToZIndexConverter" />
    </Window.Resources>
    <StackPanel
        VerticalAlignment="Center">
        <ItemsControl
            Name="scenesControl"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Padding="12, 0, 0, 0"
            ItemsSource="{Binding Scenes}"
            PreviewMouseLeftButtonDown="ScenesControl_PreviewMouseLeftButtonDown"
            MouseMove="ScenesControl_MouseMove"
            PreviewMouseLeftButtonUp="ScenesControl_PreviewMouseLeftButtonUp">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,28"
                        Visibility="{Binding Visibility}"
                        Style="{StaticResource SceneOpacity}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger
                                EventName="MouseLeftButtonUp">
                                <i:InvokeCommandAction
                                    Command="{Binding SwitchSceneCommand, Mode=OneTime, Source={x:Reference thisWindow}}"
                                    CommandParameter="{Binding .}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <!-- Windows -->
                        <ItemsControl
                            ItemsSource="{Binding Windows}"
                            AlternationCount="1000">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid
                                        Margin="0,0,0,0"></Grid>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:DwmThumbnail
                                        PreviewHandle="{Binding Handle}"
                                        Width="{Binding PreviewWidth}"
                                        Height="{Binding PreviewHeight}"
                                        Margin="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource IndexToOffsetMarginConverter}}"
                                        Panel.ZIndex="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource IndexToZIndexConverter}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <tb:TaskbarIcon
            x:Name="trayIcon"
            Visibility="Visible"
            ToolTipText="Stage Manager"
            IconSource="StageManager.ico"
            MenuActivation="LeftOrRightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu
                    Style="{StaticResource TrayContextMenuStyle}"
                    Opened="ContextMenu_Opened"
                    Closed="ContextMenu_Closed">
                    <MenuItem
                        Style="{StaticResource TrayMenuLabelStyle}"
                        Header="{Binding AppHeaderText}" />
                    <Separator Style="{StaticResource TrayMenuSeparatorStyle}" />
                    <MenuItem
                        Style="{StaticResource TrayMenuItemStyle}"
                        Header="Start with Windows"
                        IsCheckable="True"
                        IsChecked="{Binding StartsWithWindows}" />
                    <MenuItem
                        Style="{StaticResource TrayMenuItemStyle}"
                        Header="Hide desktop icons"
                        IsCheckable="True"
                        IsChecked="{Binding HideDesktopIcons, Mode=TwoWay}" />
                    <Separator Style="{StaticResource TrayMenuSeparatorStyle}" />
                    <MenuItem
                        Style="{StaticResource TrayMenuItemStyle}"
                        Header="Project page"
                        Click="MenuItem_ProjectPage_Click" />
                    <MenuItem
                        Style="{StaticResource TrayMenuItemStyle}"
                        Header="{Binding UpdateMenuText}"
                        StaysOpenOnClick="True"
                        Click="MenuItem_CheckForUpdates_Click" />
                    <Separator Style="{StaticResource TrayMenuSeparatorStyle}" />
                    <MenuItem
                        Style="{StaticResource TrayMenuItemStyle}"
                        Header="Quit"
                        Click="MenuItem_Quit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </StackPanel>
</Window>
